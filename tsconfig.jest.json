{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "noEmit": false,
    "rootDir": ".",
    "outDir": "./.jest-cache",
    "isolatedModules": false,
    "incremental": true,
    "tsBuildInfoFile": "./.jest-cache/tsbuildinfo.json"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "app/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
